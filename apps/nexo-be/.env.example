# ============================================================================
# NEXO PLATFORM - Environment Variables (Development)
# ============================================================================
# Copy this file to .env and adjust values as needed
# DO NOT commit .env files to version control
# ============================================================================

# General
NODE_ENV=development
LOG_LEVEL=debug

# ============================================================================
# Backend (nexo-be)
# ============================================================================
BE_PORT=3000
BE_HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres_dev@localhost:5432/nexo_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=nexo-dev
KEYCLOAK_CLIENT_ID=nexo-be
KEYCLOAK_CLIENT_SECRET=your-secret-here

# JWT
JWT_SECRET=your-jwt-secret-here-change-in-production

# ============================================================================
# Frontend (nexo-fe)
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=nexo-dev
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=nexo-fe

# ============================================================================
# Infrastructure
# ============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev
POSTGRES_DB=nexo_dev

# Redis
REDIS_PASSWORD=redis_dev

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_dev
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=postgres_dev

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin_dev
